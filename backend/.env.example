# Copy this to .env and fill in your values

# LLM Provider (groq, openai, or anthropic)
LLM_PROVIDER=groq

# API Keys — set one based on LLM_PROVIDER
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server
HOST=0.0.0.0
PORT=8000

# CORS — comma-separated allowed origins (NEVER use * in production)
# CORS_ORIGINS=https://your-app-domain.com

# API key for client authentication (set to a strong random string)
# COPILOT_API_KEY=your_secret_key_here

# Helius RPC URL (server-side only — NEVER put in client code)
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_key_here
